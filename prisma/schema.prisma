generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pg_trgm]
}

// -------------------- AUTH --------------------

enum Role {
  USER
  ADMIN
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  name           String?
  hashedPassword String?
  role           Role               @default(USER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accounts        Account[]
  sessions        Session[]
  savedFilters    SavedFilter[]
  agentTraces     AgentTrace[]
  conversations   ChatConversation[]
  starredListings StarredListing[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------- LISTINGS --------------------

model Listing {
  mlsId      String  @id
  address    String
  city       String?
  state      String?
  postalCode String?
  lat        Float?
  lng        Float?
  // PostGIS geography(Point,4326) column added by raw SQL migration as "geom"
  // (Prisma doesn't model PostGIS types directly; we query via $queryRaw.)

  price            Int
  daysOnMls        Int
  postDate         DateTime
  listingUpdatedAt DateTime
  status           String

  propertyType String
  sqft         Int?
  lotSizeSqft  Int?
  units        Int?
  beds         Int?
  baths        Float?
  occupancy    Float?
  yearBuilt    Int?
  stories      Int?

  // SF Assessor Secured Property Tax Roll (Socrata wv5m-vpq2) — official
  // parcel record. Filled by the second-pass enrichment script
  // `scripts/enrich-sfpim.ts`; never overwrites the Bridge MLS fields above.
  blockLot                 String?
  block                    String?
  lot                      String?
  assessorBuildingSqft     Int?
  assessorLotSqft          Int?
  assessorYearBuilt        Int?
  assessorStories          Int?
  assessorUnits            Int?
  assessorRooms            Int?
  assessorBedrooms         Int?
  assessorBathrooms        Float?
  assessorUseType          String?
  assessorConstructionType String?
  assessorBasement         String?
  assessorBuildingValue    Int?
  assessorLandValue        Int?
  assessorFetchedAt        DateTime?

  // AI building vision (gpt-4o vision). Headline fields denormalized onto
  // the Listing row for fast filtering; full output lives in AIEnrichment.
  aiStories            Int?
  aiHasBasement        Boolean?
  aiHasPenthouse       Boolean?
  aiBestPhotoUrl       String?
  renovationLevel      RenovationLevel?
  renovationConfidence Float?
  visionFetchedAt      DateTime?

  // AI listing-extract (gpt-4o-mini). Parses the public/private remarks for
  // unit mix, rent roll, capex, ADU potential. Headline fields denormalized
  // onto Listing for filtering/scoring; full output in AIEnrichment.
  extractedUnitMix           Json?
  extractedRentRoll          Json?
  extractedTotalMonthlyRent  Int?
  extractedOccupancy         Float?
  // AI-estimated market-rate rents per unit type — emitted alongside
  // unitMix even when actual rents are present in the listing, so the UI
  // can fall back to the estimate for unit types not in the rent roll.
  // Shape: [{ beds, baths, estimatedRent, rationale }].
  aiRentEstimate             Json?
  // Same shape as aiRentEstimate, but post a moderate cosmetic renovation
  // (kitchens/baths refreshed, paint, modern fixtures). Always strictly
  // higher than aiRentEstimate for the same unit type.
  postRenovationRentEstimate Json?
  recentCapex                Json?
  aduPotential               String?
  aduConfidence              Float?
  aduRationale               String?
  extractFetchedAt           DateTime?

  // generated columns added in raw SQL migration. Resolution order is now
  // ASSESSOR-first (most reliable), falling back to MLS, then AI:
  //   effectiveSqft         int      GENERATED ALWAYS AS (COALESCE(assessor_building_sqft, sqft)) STORED
  //   effectiveLotSizeSqft  int      GENERATED ALWAYS AS (COALESCE(assessor_lot_sqft, lot_size_sqft)) STORED
  //   effectiveStories      int      GENERATED ALWAYS AS (COALESCE(assessor_stories, stories, ai_stories)) STORED
  //   pricePerSqft          numeric  GENERATED ALWAYS AS (price / NULLIF(effectiveSqft, 0)) STORED
  //   pricePerUnit          numeric  GENERATED ALWAYS AS (price / NULLIF(COALESCE(assessor_units, units), 0)) STORED
  //   sqftPerUnit           numeric  GENERATED ALWAYS AS (effectiveSqft / NULLIF(COALESCE(assessor_units, units), 0)) STORED
  //   hasSizeDiscrepancy    bool     GENERATED ALWAYS AS (any pair of MLS↔Assessor sqft/lot/units/stories differs >5%) STORED

  // Location Rating inputs (added 2026-05-08).
  //   neighborhood            FK by name to Neighborhood. Backfilled by a
  //                           PostGIS ST_Intersects query during the pipeline
  //                           pass, nullable for listings outside SF polygons.
  //   walkScore               0–100 from Walk Score API, refreshed every 90d.
  //   locationScore           0.3*walkScore + 0.7*Neighborhood.crimeScore
  //                           (nulls are reweighted; see scoring/location.ts).
  neighborhood           String?
  neighborhoodRel        Neighborhood? @relation(fields: [neighborhood], references: [name], onDelete: SetNull)
  walkScore              Int?
  walkScoreFetchedAt     DateTime?
  locationScore          Float?
  locationScoreUpdatedAt DateTime?

  // Market Upside inputs (added 2026-05-08).
  //   zoningDistrict     SF Planning base district (e.g. "RH-2", "RM-1").
  //                      Resolved by `scripts/enrich-zoning.ts` via PostGIS
  //                      ST_Intersects against the `zoning_polygon` table.
  //   zoningMaxUnits     Max units allowed under base zoning, derived from
  //                      `ZoningRule` (fixed for RH-*, lot-area-based for
  //                      RM-*). Null when district has no static cap or the
  //                      rule is unmapped. Does NOT include state-law
  //                      overlays (SB-9, AB-2011, density bonuses).
  //   assessedValueTotal generated column added in raw SQL migration:
  //     GENERATED ALWAYS AS (COALESCE(assessorBuildingValue,0) +
  //                          COALESCE(assessorLandValue,0)) STORED
  zoningDistrict  String?
  zoningMaxUnits  Int?
  zoningFetchedAt DateTime?

  // Feasibility inputs (added 2026-05-08): SF Open Data signals for ADU /
  // floor-plan reconfiguration potential. See ADU-FEASIBILITY plan.
  //   landUse*       — Socrata fdfd-xptc, joined on `mapblklot == blockLot`.
  //   permits*       — denormalized summary of BuildingPermit (Socrata
  //                    i98e-djp9). Heavy raw rows live in BuildingPermit;
  //                    these counts are recomputed by `enrich:permits`.
  landUseCategory  String? // RESIDENT | MIXRES | MIXED | RETAIL/ENT | PDR | …
  landUseResUnits  Int? // resunits
  landUseResSqft   Int? // res
  landUseCommSqft  Int? // totalcomm
  landUseFetchedAt DateTime?

  permitsOwnParcelCount       Int?
  permitsOwnParcelAduCount    Int?
  permitsBlockAduRecentCount  Int?
  permitsRadiusAduRecentCount Int?
  /// `{ permitNumber, filedDate, description, address }` for the most recent
  /// ADU/legalization permit on the same `block` (excluding own parcel) —
  /// surfaces in the FeasibilityCard as a precedent breadcrumb.
  latestAduPermitOnBlock      Json?
  permitsFetchedAt            DateTime?

  // Risk & Compliance signals (added 2026-05-08): regulatory-health overlays
  // for the RiskComplianceCard + filters. Filter+display only — these do NOT
  // enter the value-add weighted average.
  //   codeViolations*   — DBI Notice of Violations (Socrata). Joined on the
  //                       canonical block||lot. Open + 5y history per parcel.
  //   housingNetUnit*   — SF Housing Inventory (Socrata 6v9b-p59r). Sum of
  //                       net unit changes attributed to this parcel over the
  //                       last 5 reporting years.
  //   rentControl*      — Pure compute from yearBuilt + units + landUse;
  //                       reflects SF rent ordinance coverage (multi-unit
  //                       residential built before 1979-06-13).
  codeViolationsOpenCount     Int?
  codeViolationsRecentCount   Int?
  /// `{ complaintNumber, dateFiled, status, description, address }` for the
  /// most recent NOV on this parcel — surfaces in the RiskComplianceCard.
  codeViolationsLatest        Json?
  codeViolationsFetchedAt     DateTime?

  housingNetUnitChange5y      Int?
  housingInventoryFetchedAt   DateTime?

  rentControlCovered          Boolean?
  rentControlComputedAt       DateTime?

  raw                         Json
  bridgeModificationTimestamp DateTime

  score         Score?
  enrichments   AIEnrichment[]
  conversations ChatConversation[]
  contact       ListingContact?
  starredBy     StarredListing[]
  createdAt     DateTime           @default(now())

  @@index([price])
  @@index([daysOnMls])
  @@index([propertyType])
  @@index([yearBuilt])
  @@index([status])
  @@index([bridgeModificationTimestamp])
  @@index([blockLot])
  @@index([renovationLevel])
  @@index([neighborhood])
  @@index([locationScore(sort: Desc)])
  @@index([zoningDistrict])
  @@index([landUseCategory])
  @@index([codeViolationsOpenCount])
  @@index([housingNetUnitChange5y])
  @@index([rentControlCovered])
}

// -------------------- BUILDING PERMITS --------------------

/// SF DBI Building Permits (Socrata i98e-djp9) — one row per permit, hydrated
/// from the same parcels we have listings on, plus the rest of the block for
/// "neighbor precedent" lookups. Idempotent: keyed on `permitNumber`. The
/// `geom` column is a PostGIS geography(Point,4326) added by raw SQL
/// migration (Prisma can't model PostGIS types directly).
model BuildingPermit {
  permitNumber             String    @id
  blockLot                 String // canonical 7-char block||lot
  block                    String
  lot                      String
  filedDate                DateTime?
  issuedDate               DateTime?
  status                   String?
  description              String?
  /// `permit.adu == "Y"` (the dataset's own ADU flag).
  aduFlag                  Boolean   @default(false)
  /// Description matches /\b(ADU|accessory dwelling|unit add|unit legaliz|legaliz.*unit)/i.
  /// Catches the many ADU/legalization permits filed before SF added the
  /// explicit `adu` column.
  aduKeyword               Boolean   @default(false)
  existingUnits            Int?
  proposedUnits            Int?
  existingConstructionType String?
  proposedConstructionType String?
  existingUse              String?
  proposedUse              String?
  lat                      Float?
  lng                      Float?
  raw                      Json
  fetchedAt                DateTime  @default(now())

  @@index([blockLot])
  @@index([block])
  @@index([filedDate])
  @@index([aduFlag])
  @@index([aduKeyword])
}

// Agent + brokerage contact details for a listing. Bridge `sfar` (IDX) strips
// `ListAgentDirectPhone`, `ListAgentEmail`, `ListOfficePhone`, etc., so the
// drawer's "Listed by" / Brokerage rows have nothing to render. We hydrate
// this table from the RentCast API (`listingAgent` + `listingOffice` blobs)
// keyed by listing address — see scripts/enrich-contacts.ts.
//
// `source` lets us swap to a future Bridge VOW/BBO feed without renaming
// columns. `fetchedAt + miss` together drive the refresh policy:
//   - hit  → refresh every 30d (catches agent moves)
//   - miss → retry monthly (RentCast may not have the address yet)
model ListingContact {
  id            String   @id @default(cuid())
  listingMlsId  String   @unique
  listing       Listing  @relation(fields: [listingMlsId], references: [mlsId], onDelete: Cascade)
  source        String // "rentcast" | "rentcast_miss" | "bridge_vow" | "manual"
  agentName     String?
  agentPhone    String?
  agentEmail    String?
  agentWebsite  String?
  officeName    String?
  officePhone   String?
  officeEmail   String?
  officeWebsite String?
  fetchedAt     DateTime @default(now())
  raw           Json?

  @@index([fetchedAt])
  @@index([source])
}

// -------------------- LOCATION --------------------

// Seeded once from DataSF "Analysis Neighborhoods" GeoJSON (resource
// p5b7-5n3h). The polygon `boundary` column is a PostGIS geography(Polygon,
// 4326), added by raw SQL since Prisma can't model PostGIS types directly.
// Crime stats are recomputed every nightly refresh from a single SoQL
// `$group` query against DataSF's wg3w-h783 incidents dataset.
model Neighborhood {
  name              String    @id
  // boundary geography(Polygon,4326) — added in raw SQL migration; queried
  // via $queryRaw with ST_Intersects for listing→neighborhood join.
  crimeScore        Float? // 0–100, higher = safer (percentile-ranked across SF)
  weightedIncidents Float? // raw weighted incident count (debugging)
  crimeUpdatedAt    DateTime?

  // Market Upside comp aggregates (added 2026-05-08). Recomputed wholesale
  // by `scripts/refresh-neighborhood-comps.ts` from the Listing table.
  // medianAssessed* uses any listing with assessor totals (active+pending+
  // sold) since assessment delta is a within-cohort comparison.
  // medianSoldPrice* uses status IN ('Sold','Closed') with postDate within
  // the last 24 months. compSampleSize is the smaller of the two cohorts;
  // downstream scoring returns null when sampleSize < 5.
  medianAssessedPerSqft  Float?
  medianAssessedPerUnit  Float?
  medianSoldPricePerSqft Float?
  medianSoldPricePerUnit Float?
  compSampleSize         Int?
  compsUpdatedAt         DateTime?

  listings   Listing[]
  crimeStats NeighborhoodCrimeStat[]
}

// Curated mapping of SF Planning base zoning district → max-allowed units.
// Seeded once via `scripts/seed-zoning-rules.ts`. RH-* set `maxUnitsFixed`
// directly; RM-* use `maxUnitsPerLotSqft` (e.g. RM-1 = 1 unit per 800 sqft
// of lot area). NCT/C-3 districts are seeded with both columns null and a
// `notes` string so the enrichment script can flag "no static cap" without
// re-querying.
//
// State-law overlays (SB-9, AB-2011, density bonuses) are explicitly NOT
// modeled here — v1 only reflects base zoning. The UI surfaces this caveat
// next to the under-utilization signal.
model ZoningRule {
  district           String  @id
  maxUnitsFixed      Int?
  maxUnitsPerLotSqft Float?
  notes              String?
}

// Per-neighborhood/category aggregate for the rolling 12-month window.
// Replaced wholesale on each `pnpm refresh:crime` run — rows from prior
// windows are deleted, so this table is small (~120 rows: 41 × 3 categories).
model NeighborhoodCrimeStat {
  neighborhood String
  category     String // "violent" | "property" | "qol"
  count        Int
  windowStart  DateTime
  windowEnd    DateTime

  neighborhoodRel Neighborhood @relation(fields: [neighborhood], references: [name], onDelete: Cascade)

  @@id([neighborhood, category, windowStart])
  @@index([neighborhood])
}

enum RenovationLevel {
  DISTRESSED
  ORIGINAL
  UPDATED
  RENOVATED
}

enum ScoreSource {
  HEURISTIC
  AI
}

model Score {
  listingMlsId String  @id
  listing      Listing @relation(fields: [listingMlsId], references: [mlsId], onDelete: Cascade)

  densityScore         Float
  vacancyScore         Float
  motivationScore      Float
  // Added 2026-05-08: stored as nullable so we can backfill incrementally.
  // `locationScore` mirrors Listing.locationScore at score-time; `aduScore`
  // is the numeric mapping of Listing.aduPotential. Both feed into
  // valueAddWeightedAvg under the new 5-component scheme.
  locationScore        Float?
  aduScore             Float?
  // Market Upside (added 2026-05-08). Two sub-signals plus a combined
  // top-line score. Computed and surfaced but NOT folded into
  // valueAddWeightedAvg in v1 — we want to validate the signal in the UI
  // before changing the grid sort key.
  //   assessmentDeltaScore  Assessor total vs. neighborhood comp median.
  //   zoningUpsideScore     Current units vs. base-zoning max (no overlays).
  //   marketUpsideScore     Average of non-null sub-scores; null if both null.
  assessmentDeltaScore Float?
  zoningUpsideScore    Float?
  marketUpsideScore    Float?
  valueAddWeightedAvg  Float
  breakdown            Json
  computedBy           ScoreSource
  computedAt           DateTime    @default(now())
  // Fingerprint of the AI-scoring input payload (sha256 of stable-key JSON).
  // The nightly delta-AI job uses this to skip listings whose inputs haven't
  // changed since the last AI run. Null = never AI-scored.
  aiInputHash          String?

  // Parallel AI-scored variants. The columns above (densityScore,
  // vacancyScore, motivationScore, valueAddWeightedAvg, breakdown) are
  // always heuristic and refreshed by `recompute:scores` every nightly.
  // AI scoring writes only to the columns below, so the UI can sort by
  // either source independently. Null until the listing has been
  // AI-scored at least once.
  aiDensityScore         Float?
  aiVacancyScore         Float?
  aiMotivationScore      Float?
  aiValueAddWeightedAvg  Float?
  aiBreakdown            Json?
  aiComputedAt           DateTime?

  @@index([valueAddWeightedAvg(sort: Desc)])
  @@index([densityScore(sort: Desc)])
  @@index([vacancyScore(sort: Desc)])
  @@index([motivationScore(sort: Desc)])
  @@index([locationScore(sort: Desc)])
  @@index([aduScore(sort: Desc)])
  @@index([marketUpsideScore(sort: Desc)])
  @@index([aiValueAddWeightedAvg(sort: Desc)])
  @@index([aiDensityScore(sort: Desc)])
  @@index([aiVacancyScore(sort: Desc)])
  @@index([aiMotivationScore(sort: Desc)])
}

model AIEnrichment {
  id           String   @id @default(cuid())
  listingMlsId String
  agentName    String
  output       Json
  createdAt    DateTime @default(now())

  listing Listing @relation(fields: [listingMlsId], references: [mlsId], onDelete: Cascade)

  @@index([listingMlsId, agentName])
}

// -------------------- ETL / OPS --------------------

enum SyncStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model SyncRun {
  id              String     @id @default(cuid())
  startedAt       DateTime   @default(now())
  finishedAt      DateTime?
  status          SyncStatus @default(RUNNING)
  recordsUpserted Int        @default(0)
  recordsScored   Int        @default(0)
  cursorFrom      DateTime?
  cursorTo        DateTime?
  error           String?

  progressMessage String?
  progressCurrent Int?
  progressTotal   Int?
  logs            Json?

  @@index([startedAt(sort: Desc)])
}

model AgentTrace {
  id        String   @id @default(cuid())
  agentName String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  input     Json
  output    Json?
  steps     Json?
  tokens    Int?
  latencyMs Int?
  error     String?
  createdAt DateTime @default(now())

  @@index([agentName, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String
  payload   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model StarredListing {
  userId       String
  listingMlsId String
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingMlsId], references: [mlsId], onDelete: Cascade)

  @@id([userId, listingMlsId])
  @@index([userId, createdAt(sort: Desc)])
}

// -------------------- CHAT --------------------

enum ChatScope {
  ASSET
  GLOBAL
}

enum ChatRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

model ChatConversation {
  id             String    @id @default(cuid())
  userId         String
  scope          ChatScope
  // Set when scope=ASSET: the listing this thread is about.
  listingMlsId   String?
  // Set when scope=GLOBAL: the FilterInput snapshot at thread creation
  // time. Frozen for the life of the conversation; UI offers a fresh
  // thread to pick up the latest filter rather than mutating mid-thread.
  filterSnapshot Json?
  // Auto-generated from the first user message; user can rename.
  title          String
  pinned         Boolean   @default(false)
  archived       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing  Listing?      @relation(fields: [listingMlsId], references: [mlsId], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, scope, listingMlsId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           ChatRole
  content        String   @db.Text
  // OpenAI tool_calls payload from the assistant turn (if any).
  toolCalls      Json?
  // For role=TOOL only — which tool produced this message.
  toolName       String?
  // For role=TOOL only — links back to the tool_call id from the assistant
  // message so we can rebuild the OpenAI messages array on resume.
  toolCallId     String?
  // MLS IDs the assistant cited in this message; used for citation chips.
  citedMlsIds    String[]
  tokensIn       Int?
  tokensOut      Int?
  errored        Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
