{
  "name": "propscore",
  "version": "0.1.0",
  "private": true,
  "description": "MLS Property Opportunity Scoring System",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx --env-file=.env scripts/dev.ts",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3020}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "etl:sync": "tsx --env-file=.env scripts/etl-sync.ts",
    "etl:full": "tsx --env-file=.env scripts/etl-sync.ts --full",
    "nightly": "pnpm etl:sync && pnpm enrich:sfpim && pnpm enrich:vision && pnpm enrich:listings && pnpm recompute:scores",
    "render:sync": "tsx --env-file=.env scripts/render-sync.ts",
    "render:sync:dry": "tsx --env-file=.env scripts/render-sync.ts --dry-run",
    "bootstrap:bridge": "tsx --env-file=.env scripts/bootstrap-bridge.ts",
    "recompute:scores": "tsx --env-file=.env scripts/recompute-scores.ts",
    "enrich:sfpim": "tsx --env-file=.env scripts/enrich-sfpim.ts",
    "enrich:vision": "tsx --env-file=.env scripts/enrich-vision.ts",
    "enrich:listings": "tsx --env-file=.env scripts/enrich-listings-extract.ts",
    "backfill:rent-estimates": "tsx --env-file=.env scripts/backfill-rent-estimates.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@emotion/cache": "^11.13.5",
    "@emotion/react": "^11.13.5",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@mui/material-nextjs": "^6.4.0",
    "@mui/x-data-grid": "^7.23.0",
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.7",
    "prisma": "^6.1.0",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0-rc.660",
    "@trpc/next": "^11.0.0-rc.660",
    "@trpc/react-query": "^11.0.0-rc.660",
    "@trpc/server": "^11.0.0-rc.660",
    "bcryptjs": "^2.4.3",
    "maplibre-gl": "^4.7.1",
    "next": "^15.1.3",
    "next-auth": "5.0.0-beta.25",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^7.1.7",
    "recharts": "^2.15.0",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
