{
  "name": "propscore",
  "version": "0.1.0",
  "private": true,
  "description": "MLS Property Opportunity Scoring System",
  "engines": {
    "node": ">=20.16.0"
  },
  "scripts": {
    "dev": "tsx -r ./scripts/load-env.cjs scripts/dev.ts",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3020}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "etl:sync": "tsx -r ./scripts/load-env.cjs scripts/etl-sync.ts",
    "etl:full": "tsx -r ./scripts/load-env.cjs scripts/etl-sync.ts --full",
    "nightly": "tsx -r ./scripts/load-env.cjs scripts/nightly.ts",
    "nightly:base": "tsx -r ./scripts/load-env.cjs scripts/nightly.ts --mode=base",
    "nightly:llm": "tsx -r ./scripts/load-env.cjs scripts/nightly.ts --mode=llm",
    "offboard:stale": "tsx -r ./scripts/load-env.cjs scripts/offboard-stale.ts",
    "seed:neighborhoods": "tsx -r ./scripts/load-env.cjs scripts/seed-neighborhoods.ts",
    "refresh:crime": "tsx -r ./scripts/load-env.cjs scripts/refresh-crime.ts",
    "refresh:walkscore": "tsx -r ./scripts/load-env.cjs scripts/refresh-walkscore.ts",
    "render:sync": "tsx -r ./scripts/load-env.cjs scripts/render-sync.ts",
    "render:sync:dry": "tsx -r ./scripts/load-env.cjs scripts/render-sync.ts --dry-run",
    "bootstrap:bridge": "tsx -r ./scripts/load-env.cjs scripts/bootstrap-bridge.ts",
    "recompute:scores": "tsx -r ./scripts/load-env.cjs scripts/recompute-scores.ts",
    "ai-score:changed": "tsx -r ./scripts/load-env.cjs scripts/ai-score-changed.ts",
    "enrich:sfpim": "tsx -r ./scripts/load-env.cjs scripts/enrich-sfpim.ts",
    "enrich:vision": "tsx -r ./scripts/load-env.cjs scripts/enrich-vision.ts",
    "enrich:vision-interior": "tsx -r ./scripts/load-env.cjs scripts/enrich-vision-interior.ts",
    "enrich:listings": "tsx -r ./scripts/load-env.cjs scripts/enrich-listings-extract.ts",
    "enrich:rent-comps": "tsx -r ./scripts/load-env.cjs scripts/enrich-rent-comps.ts",
    "enrich:contacts": "tsx -r ./scripts/load-env.cjs scripts/enrich-contacts.ts",
    "enrich:landuse": "tsx -r ./scripts/load-env.cjs scripts/enrich-landuse.ts",
    "enrich:permits": "tsx -r ./scripts/load-env.cjs scripts/enrich-permits.ts",
    "enrich:code-enforcement": "tsx -r ./scripts/load-env.cjs scripts/enrich-code-enforcement.ts",
    "enrich:dbi-complaints": "tsx -r ./scripts/load-env.cjs scripts/enrich-dbi-complaints.ts",
    "enrich:housing-inventory": "tsx -r ./scripts/load-env.cjs scripts/enrich-housing-inventory.ts",
    "enrich:soft-story": "tsx -r ./scripts/load-env.cjs scripts/enrich-soft-story.ts",
    "compute:rent-control": "tsx -r ./scripts/load-env.cjs scripts/compute-rent-control.ts",
    "enrich:zoning": "tsx -r ./scripts/load-env.cjs scripts/enrich-zoning.ts",
    "seed:zoning-rules": "tsx -r ./scripts/load-env.cjs scripts/seed-zoning-rules.ts",
    "refresh:neighborhood-comps": "tsx -r ./scripts/load-env.cjs scripts/refresh-neighborhood-comps.ts",
    "backfill:rent-estimates": "tsx -r ./scripts/load-env.cjs scripts/backfill-rent-estimates.ts",
    "emails:poll": "tsx -r ./scripts/load-env.cjs scripts/poll-gmail-replies.ts",
    "emails:cleanup-orphans": "tsx -r ./scripts/load-env.cjs scripts/cleanup-gmail-orphan-users.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@emotion/cache": "^11.13.5",
    "@emotion/react": "^11.13.5",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@mui/material-nextjs": "^6.4.0",
    "@mui/x-data-grid": "^7.23.0",
    "@prisma/client": "^6.1.0",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0-rc.660",
    "@trpc/next": "^11.0.0-rc.660",
    "@trpc/react-query": "^11.0.0-rc.660",
    "@trpc/server": "^11.0.0-rc.660",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "googleapis": "^171.4.0",
    "maplibre-gl": "^4.7.1",
    "next": "^15.1.3",
    "next-auth": "5.0.0-beta.25",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "prisma": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^7.1.7",
    "recharts": "^2.15.0",
    "superjson": "^2.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
