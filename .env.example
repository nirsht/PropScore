# --- Postgres (Render) ---
# Use the EXTERNAL Render URL for local dev. Use the INTERNAL one when running inside Render.
DATABASE_URL="postgresql://propscore_user:PASSWORD@HOST.ohio-postgres.render.com/propscore?sslmode=require"

# Optional second URL for `prisma migrate dev` against a scratch DB. Leave empty to disable migrations
# from the local machine (recommended — let Render's release command apply migrations to prod).
SHADOW_DATABASE_URL=""

# --- Bridge Data Output API ---
# Server token (Bearer) is what the ETL uses.
BRIDGE_SERVER_TOKEN="33e1d3850ed0a0e84c51c7cc068b33f9"
BRIDGE_DATASET="sfar"
BRIDGE_BASE_URL="https://api.bridgedataoutput.com/api/v2/OData"

# --- OpenAI ---
OPENAI_API_KEY="sk-proj-REPLACE_ME"
OPENAI_MODEL="gpt-4o-2024-11-20"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3020"

# --- App ---
PORT=3020
NODE_ENV=development

# --- Map ---
# Optional. MapLibre uses free OSM tiles by default; set this to a MapTiler/Mapbox style URL for nicer maps.
NEXT_PUBLIC_MAP_STYLE_URL=""
